#pragma once

/* Define to 1 if you have the gcc <cpuid.h> header file. */
#cmakedefine HAVE_CPUID_H 1

/* Define to 1 if you have the MSVC <intrin.h> header file. */
#cmakedefine HAVE_INTRIN_H 1

/* Define to 1 if MSVC intrin.h has __cpuid() */
#cmakedefine HAVE_MSVC_CPUID 1
